{
  "name": "mewsy",
  "version": "0.1.0",
  "description": "Mews → Sage 50 Revenue Integration Service — posts Mews revenue to Sage 50 via the HyperAccounts API",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mewsy": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run test/hyperext-sandbox.live.test.ts --reporter=verbose"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "commander": "^12.1.0",
    "luxon": "^3.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
