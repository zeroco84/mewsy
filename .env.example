# Mewsy environment — copy to .env (or set in the service environment) and fill in.
# Secrets live ONLY here; config/mewsy.json references them by env-var name.

# --- Mews Connector API ---
# Production: https://api.mews.com   Demo: https://api.mews-demo.com
MEWS_BASE_URL=https://api.mews-demo.com
MEWS_CLIENT_TOKEN=your-mews-client-token

# One AccessToken per property (the AccessToken selects the Mews enterprise/property).
# Name them however you like; config/mewsy.json points at these names.
MEWS_ACCESS_TOKEN_PROP1=your-mews-access-token-for-property-1

# --- HyperAccounts (on the Sage box, reached over localhost) ---
# One instance/token per Sage company (one Sage company per property).
HYPERACCOUNTS_TOKEN_PROP1=your-hyperaccounts-auth-token-for-property-1

# --- Alerting (optional) ---
# Any endpoint accepting a JSON POST ({severity,event,propertyCode,businessDate,message,detail}).
#MEWSY_ALERT_WEBHOOK=https://hooks.example.com/mewsy

# --- Storage (optional overrides) ---
#MEWSY_DB=./data/mewsy.db
#MEWSY_CONFIG=./config/mewsy.json
#MEWSY_REPORT_DIR=./data/reports
